generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// HR Toolkit models
model Task {
  id            String   @id @default(cuid())
  title         String
  sub           String?
  dueTag        String?
  status        String   @default("todo") // todo | doing | done
  statusHistory String   @default("[]") // JSON: [{status, timestamp}]
  notes         String   @default("[]") // JSON: [{date, text}]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PtoEntry {
  id         String   @id @default(cuid())
  employee   String
  type       String   @default("PTO")
  start      DateTime?
  end        DateTime?
  days       Float?
  status     String   @default("Approved")
  sourceFile String?
  createdAt  DateTime @default(now())
}

model Employee {
  id                 String   @id @default(cuid())
  name               String
  role               String
  dept               String   @default("Operations") // Attorneys | Operations
  birthday           DateTime?
  anniversaryDate    DateTime?
  anniversaryYears   Int?
  review6moStatus    String?
  review6moDate      DateTime?
  review6moReviewer  String?
  review6moSummary   String?
  review1yrStatus    String?
  review1yrDate      DateTime?
  review1yrReviewer  String?
  review1yrSummary   String?
  externalReviewUrl  String?
  createdAt          DateTime @default(now())
}

model PayrollPeriod {
  id        String   @id @default(cuid())
  runDate   DateTime
  period    String
  cutoff    DateTime
  status    String   @default("Upcoming") // Upcoming | Processing | Paid
  createdAt DateTime @default(now())
}

model PayrollSettings {
  id               String  @id @default(cuid())
  cadence          String  @default("Semi-monthly")
  reminderToggles  String  @default("{\"cutoff\":true,\"payrun\":true,\"timesheet\":false}")
}

model Trip {
  id        String   @id @default(cuid())
  who       String
  detail    String
  cost      Float?
  matter    String?
  status    String   @default("Pending") // Pending | Approved | Hold
  createdAt DateTime @default(now())
}

model InsuranceInvoice {
  id             String   @id @default(cuid())
  carrier        String
  invoiceType    String?
  amount         Float
  deadline       DateTime
  coveragePeriod String?
  enrolledCount  Int?
  attachments    String   @default("[]") // JSON array of file names
  createdAt      DateTime @default(now())
}

model Reimbursement {
  id          String   @id @default(cuid())
  employee    String
  purpose     String
  amount      Float
  payoutDate  DateTime?
  attachments String   @default("[]")
  receipts    String   @default("[]")
  createdAt   DateTime @default(now())
}

model ContractorPayment {
  id        String   @id @default(cuid())
  name      String
  dueDate   DateTime?
  paidDate  DateTime?
  amount    Float
  note      String?
  createdAt DateTime @default(now())
}

model Overtime {
  id        String   @id @default(cuid())
  employee  String
  hours     Float
  amount    Float
  createdAt DateTime @default(now())
}

model CashoutLedger {
  id        String   @id @default(cuid())
  date      DateTime
  payee     String
  category  String
  amount    Float
  status    String   @default("Paid")
  createdAt DateTime @default(now())
}

model AppSettings {
  id                       String  @id @default(cuid())
  firmName                 String  @default("Litson")
  payrollCadence           String  @default("Semi-monthly")
  externalReviewDashboard  String?
  letterheadImage          String?
  signatureImage           String?
}

model IntegrationToken {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
}
