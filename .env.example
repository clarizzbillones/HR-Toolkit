# ── Required ──────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to SQLite for local dev. Swap provider to postgresql + set this URL
# to enable Postgres (Supabase/Neon free tier works great).
# DATABASE_URL="postgresql://user:pass@host:5432/litson_hr?schema=public"
DATABASE_URL="file:./prisma/dev.db"

# ── Microsoft 365 / Entra ID (unlocks Sign-in + Outlook Calendar sync) ────────
# Register an app in https://entra.microsoft.com → App registrations
# Redirect URI: http://localhost:3000/api/auth/callback/azure-ad
# Delegated scopes: openid profile email offline_access User.Read Calendars.Read MailboxSettings.Read Mail.Send
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# ── Anthropic AI (unlocks real AI drafting for Offer Letters & SOP Builder) ───
# Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
